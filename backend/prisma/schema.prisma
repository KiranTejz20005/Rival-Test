generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String        @id @default(uuid())
  email           String        @unique
  passwordHash    String
  role            Role          @default(USER)
  isActive        Boolean       @default(true)
  refreshTokenHash String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  tasks           Task[]        @relation("TaskAssignee")
  createdTasks    Task[]        @relation("TaskCreator")
  activityLogs    ActivityLog[]

  @@index([role])
  @@index([isActive])
  @@index([role, isActive])
  @@index([email])
  @@index([createdAt])
  @@map("users")
}

model Task {
  id           String        @id @default(uuid())
  userId       String?
  assignedRole Role?
  createdById  String?
  title        String
  description  String?
  status       Status        @default(TODO)
  priority     Priority      @default(MEDIUM)
  dueDate      DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user         User?         @relation("TaskAssignee", fields: [userId], references: [id], onDelete: Cascade)
  createdBy    User?         @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  activityLogs ActivityLog[]
  attachments  Attachment[]

  @@index([userId])
  @@index([createdById])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@index([dueDate])
  @@index([userId, status])
  @@index([userId, priority])
  @@index([userId, createdAt])
  @@index([assignedRole, status])
  @@index([priority, status])
  @@index([status, dueDate])
  @@map("tasks")
}

model ActivityLog {
  id        String   @id @default(uuid())
  taskId    String
  userId    String?
  action    String
  changes   Json?
  timestamp DateTime @default(now())

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([userId])
  @@index([action])
  @@index([timestamp])
  @@index([taskId, timestamp])
  @@index([action, timestamp])
  @@map("activity_logs")
}

enum Status {
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum Role {
  USER
  ADMIN
}

model AuthLog {
  id        String   @id @default(uuid())
  email     String
  action    String
  ip        String?
  timestamp DateTime @default(now())

  @@index([email])
  @@index([action])
  @@index([timestamp])
  @@index([email, timestamp])
  @@index([action, timestamp])
  @@map("auth_logs")
}

model Attachment {
  id           String   @id @default(uuid())
  taskId       String
  originalName String
  mimeType     String
  size         Int
  data         Bytes
  createdAt    DateTime @default(now())

  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("attachments")
}